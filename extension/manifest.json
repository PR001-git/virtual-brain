{
  "manifest_version": 3,
  "name": "VirtualBrain Tab Capture",
  "version": "0.1.0",
  "description": "Capture tab audio and stream to VirtualBrain for live transcription.",
  "permissions": ["tabCapture", "activeTab", "offscreen"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "VirtualBrain"
  },
  "background": {
    "service_worker": "background.js"
  }
}
