# VirtualBrain Configuration
# Copy this file to .env and modify as needed.
# All values below are the defaults — only set what you want to change.

# Python service
VB_HOST=0.0.0.0
VB_PYTHON_PORT=8100

# Whisper transcription
VB_WHISPER_MODEL=small              # tiny, base, small, medium, large-v2
VB_WHISPER_DEVICE=cpu               # cpu or cuda (GPU)
VB_WHISPER_COMPUTE_TYPE=int8        # int8, float16, float32

# Audio chunking
VB_CHUNK_DURATION=3.0               # seconds per chunk

# Ollama LLM
VB_OLLAMA_URL=http://localhost:11434
VB_OLLAMA_MODEL=mistral

# Memory buffer
VB_MEMORY_MAX_SEGMENTS=200          # max transcript segments kept in memory
VB_MEMORY_PRUNE_COUNT=100           # segments to drop when buffer is full

# Node service
VB_NODE_PORT=8200
VB_NODE_URL=http://localhost:8200
VB_CLIENT_ORIGIN=http://localhost:3000
